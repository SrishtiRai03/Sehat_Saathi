# Environment Variables for Sehat Saathi
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=development

# JWT Secret (change this in production!)
JWT_SECRET=your-secure-secret-key-here

# CORS Origin (restrict in production)
CORS_ORIGIN=http://localhost:5173

# Database (future: replace in-memory store)
# DATABASE_URL=sqlite://./data/sehat-saathi.db

# SMS Gateway (future: Twilio integration)
# TWILIO_ACCOUNT_SID=your-sid
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# ABHA Integration (future)
# ABHA_API_URL=https://healthidsbx.abdm.gov.in
# ABHA_CLIENT_ID=your-client-id
# ABHA_CLIENT_SECRET=your-client-secret
